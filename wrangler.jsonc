{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "readme",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "main": "./dist/_worker.js",
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
